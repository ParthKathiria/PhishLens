{
    "manifest_version": 3,
    "key": "",
    "name": "Phish Lens",
    "version": "0.1.0",
    "description": "Real-time phishing and spam detection for Gmail.",
    "permissions": [
        "identity",
        "storage",
        "activeTab",
        "scripting"
    ],
    "host_permissions": [
        "https://mail.google.com/*",
        "https://gmail.googleapis.com/*",
        "https://dns.cloudflare.com/*"
    ],
    "background": {
        "service_worker": "background/service_worker.js",
        "type": "module"
    },
    "content_scripts": [
        {
            "matches": ["https://mail.google.com/*"],
            "js": ["content/gmail_injector.js"],
            "run_at": "document_idle"
        }
    ],
    "action": {
        "default_popup": "popup/popup.html",
        "default_icon": "icons/icon128.png"
    },
    "oauth2": {
        "client_id": "827249624897-7kn8dc77bmcvu99fpkb1s8qi6jkpl8n7.apps.googleusercontent.com",
        "scopes": [
            "https://www.googleapis.com/auth/gmail.readonly"
        ]
    }
}